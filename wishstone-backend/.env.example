# ─── SERVER ──────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── DATABASE ─────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/wishstone?retryWrites=true&w=majority

# ─── AUTH ─────────────────────────────────────────────────────
# Must be at least 32 characters in production
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ─── CORS ─────────────────────────────────────────────────────
# Your deployed frontend URLs (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com
ADMIN_URL=https://your-admin-domain.com

# ─── CLOUDINARY (Required for image uploads in production) ─────
# Get these from https://cloudinary.com (FREE tier available)
# Cloudinary stores images permanently - Render/Heroku filesystem is temporary!
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── BACKEND URL ───────────────────────────────────────────────
# Used for local file serving fallback (when Cloudinary not configured)
BACKEND_URL=https://wishstone.onrender.com
